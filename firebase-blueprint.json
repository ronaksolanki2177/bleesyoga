{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile containing personal contact information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "name": { "type": "string", "description": "Full name of the user" },
        "email": { "type": "string", "description": "Email address of the user" },
        "phone": { "type": "string", "description": "Phone number of the user" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when doc was created" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Timestamp when doc was updated" }
      },
      "required": ["uid", "name", "email", "phone", "createdAt", "updatedAt"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Solo Private Yoga Class Booking",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique booking reference ID" },
        "userId": { "type": "string", "description": "User UID who made the booking" },
        "packageName": { "type": "string", "description": "Name of the booking service/pack" },
        "sessions": { "type": "integer", "description": "Number of sessions" },
        "price": { "type": "integer", "description": "Total price paid" },
        "clientName": { "type": "string", "description": "Booking client full name" },
        "clientEmail": { "type": "string", "description": "Booking client email" },
        "clientPhone": { "type": "string", "description": "Booking client phone number" },
        "selectedDate": { "type": "string", "format": "date", "description": "Scheduled date" },
        "selectedTime": { "type": "string", "description": "Scheduled time slot" },
        "status": { "type": "string", "enum": ["confirmed", "cancelled"], "description": "Booking state" },
        "bookingType": { "type": "string", "description": "Usually solo" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when doc was created" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Timestamp when doc was updated" }
      },
      "required": [
        "id",
        "userId",
        "packageName",
        "sessions",
        "price",
        "clientName",
        "clientEmail",
        "clientPhone",
        "selectedDate",
        "selectedTime",
        "status",
        "bookingType",
        "createdAt",
        "updatedAt"
      ]
    },
    "Instructor": {
      "title": "Instructor",
      "description": "Instructor public profile configuration settings",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Instructor full name" },
        "role": { "type": "string", "description": "Instructor professional role title" },
        "photoUrl": { "type": "string", "description": "URL or base64 data for profile portrait" },
        "bio1": { "type": "string", "description": "Biography paragraph 1" },
        "bio2": { "type": "string", "description": "Biography paragraph 2" },
        "bio3": { "type": "string", "description": "Biography paragraph 3" },
        "usePhotoUrlAsDefault": { "type": "boolean", "description": "Whether to display custom photo by default" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Timestamp when doc was last updated" }
      },
      "required": [
        "name",
        "role",
        "photoUrl",
        "bio1",
        "bio2",
        "bio3",
        "usePhotoUrlAsDefault",
        "updatedAt"
      ]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles containing name, email, and phone"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "User scheduled yoga class bookings"
    },
    "/settings/{settingId}": {
      "schema": "Instructor",
      "description": "Dynamic configuration settings such as the instructor profile and custom graphics"
    }
  }
}
